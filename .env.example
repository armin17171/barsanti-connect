# ---- Barsanti Connect: configurazione ----
# Copia questo file in ".env" e modifica i valori prima di avviare.
#   cp .env.example .env

# Credenziali del database PostgreSQL (usate sia dal DB che dall'app)
POSTGRES_USER=barsanti
POSTGRES_PASSWORD=cambia_questa_password_db
POSTGRES_DB=barsanti_connect

# URL completo di connessione al DB (deve combaciare con i valori qui sopra).
# host "db" = nome del servizio Postgres in docker-compose.
DATABASE_URL=postgresql+psycopg://barsanti:cambia_questa_password_db@db:5432/barsanti_connect

# Chiave segreta per firmare i cookie di sessione.
# GENERANE UNA NUOVA E CASUALE, es: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_questa_chiave_segreta_molto_lunga_e_casuale

# Primo account amministratore creato automaticamente al primo avvio.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_questa_password_admin

# Porta su cui l'app è raggiungibile nella LAN (http://IP_MACCHINA:APP_PORT)
APP_PORT=8000

# Dimensione massima upload media in MB
MAX_UPLOAD_MB=15
